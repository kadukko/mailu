# Mailu main configuration file
# For a detailed list of configuration variables, see:
# https://mailu.io/master/configuration.html

###################################
# Common configuration variables
###################################

# Set to a randomly generated 16 bytes string
SECRET_KEY=ChangeMeToA16ByteRandomString

# Subnet of the docker network (adjust if conflicts with your LAN)
SUBNET=192.168.203.0/24

# Main mail domain
DOMAIN=example.com

# Hostnames for this server, separated with comas
HOSTNAMES=mail.example.com

# Postmaster local part (will append @DOMAIN)
POSTMASTER=admin

# Choose how incoming mail is handled if no valid recipient exists
# Options: reject (550 error), accept (accept and silently discard), lmtp (deliver to lmtp)
RECIPIENT_DELIMITER=+

# DKIM/DMARC/SPF settings
DKIM_SELECTOR=dkim
DKIM_PATH=/dkim/{domain}.{selector}.key

# Logging level (CRITICAL / ERROR / WARNING / INFO / DEBUG)
LOG_LEVEL=WARNING

###################################
# Exposed ports
###################################

# Bind address for public services
BIND_ADDRESS4=0.0.0.0
BIND_ADDRESS6=::1

# HTTP and HTTPS ports for the web interfaces
WEB_PORT=443

###################################
# Web settings
###################################

# Path to the admin interface (use / for root or /admin for subpath)
WEB_ADMIN=/admin

# Path to the webmail (use /webmail)
WEB_WEBMAIL=/webmail

# Website name displayed in admin
SITENAME=Mailu

# Linked website URL
WEBSITE=https://mail.example.com

###################################
# Advanced settings
###################################

# Choose the webmail client (roundcube, snappymail, none)
WEBMAIL=roundcube

# Antivirus solution (clamav, none) - clamav requires at least 2GB RAM
ANTIVIRUS=none

# Message size limit in bytes (default 50MB)
MESSAGE_SIZE_LIMIT=50000000

# Message rate limit per user per day (0 = unlimited)
MESSAGE_RATELIMIT=200/day

# Networks granted relay permissions (comma separated CIDRs)
RELAYNETS=

# AWS SES SMTP relay for outgoing mail
# Format: [server]:port
# Regions: email-smtp.us-east-1, email-smtp.sa-east-1, email-smtp.eu-west-1, etc.
RELAYHOST=[email-smtp.us-east-1.amazonaws.com]:587
RELAY_USER=AKIA_SES_ACCESS_KEY_AQUI
RELAY_PASSWORD=SES_SECRET_KEY_AQUI

# Fetchmail delay in seconds
FETCHMAIL_DELAY=600

# Enable the admin UI
ADMIN=true

# TLS flavor (cert, letsencrypt, mail, mail-letsencrypt, notls)
# Use "letsencrypt" for automatic Let's Encrypt certificates
# Use "cert" if you provide your own certs
# Use "mail" for self-signed
TLS_FLAVOR=letsencrypt

# Authentication rate limit per IP (per minute/hour)
AUTH_RATELIMIT_IP=60/hour
AUTH_RATELIMIT_USER=100/day

# Opt-out of statistics
DISABLE_STATISTICS=True

###################################
# Database settings
###################################

# Database back end (sqlite, mysql, postgresql)
DB_FLAVOR=sqlite
