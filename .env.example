###################################
# OBRIGATORIAS
###################################

# Chave secreta (gerar com: openssl rand -hex 16)
SECRET_KEY=

# Dominio principal de e-mail
DOMAIN=seudominio.com

# Hostname completo do servidor de e-mail
HOSTNAMES=mail.seudominio.com

# URL do site
WEBSITE=https://mail.seudominio.com

###################################
# AWS SES (envio de e-mail)
###################################

# Endpoint SMTP do SES (ajuste a regiao)
# Regioes: us-east-1, sa-east-1, eu-west-1, eu-central-1
RELAYHOST=[email-smtp.sa-east-1.amazonaws.com]:587

# Credenciais SMTP do SES (gerar em SES -> SMTP settings -> Create SMTP credentials)
RELAY_USER=
RELAY_PASSWORD=

###################################
# TLS
###################################

# Tipo de TLS para portas de e-mail
# letsencrypt = certificado automatico (precisa da porta 80 livre)
# mail        = auto-assinado (recomendado para Easypanel)
# cert        = certificado proprio
# notls       = sem TLS (nao recomendado)
TLS_FLAVOR=mail

###################################
# WEB
###################################

# Path do painel admin
WEB_ADMIN=/admin

# Path do webmail
WEB_WEBMAIL=/webmail

# Cliente webmail (roundcube, snappymail, none)
WEBMAIL=roundcube

# Nome exibido no admin
SITENAME=Mailu

# Habilitar painel admin
ADMIN=true

###################################
# LIMITES
###################################

# Tamanho maximo de e-mail em bytes (50MB)
MESSAGE_SIZE_LIMIT=50000000

# Limite de envio por usuario por dia
MESSAGE_RATELIMIT=200/day

# Rate limit de autenticacao
AUTH_RATELIMIT_IP=60/hour
AUTH_RATELIMIT_USER=100/day

###################################
# REDE
###################################

# Subnet da rede Docker interna (mudar se conflitar com outro projeto)
SUBNET=192.168.203.0/24

# Parte local do postmaster (postmaster@DOMAIN)
POSTMASTER=admin

# Delimitador de sub-endereco (user+tag@domain)
RECIPIENT_DELIMITER=+

# CIDRs com permissao de relay (separados por virgula)
RELAYNETS=

###################################
# AVANCADO
###################################

# Nivel de log (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=WARNING

# Banco de dados (sqlite, mysql, postgresql)
DB_FLAVOR=sqlite

# Antivirus (clamav ou none, clamav usa +2GB RAM)
ANTIVIRUS=none

# Intervalo do fetchmail em segundos
FETCHMAIL_DELAY=600

# Seletor DKIM
DKIM_SELECTOR=dkim

# Desativar envio de estatisticas anonimas
DISABLE_STATISTICS=True
