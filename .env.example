###################################
# OBRIGATORIAS
###################################

# Chave secreta (gerar com: openssl rand -hex 16)
SECRET_KEY=

# Dominio principal de e-mail
DOMAIN=seudominio.com

# Hostname completo do servidor de e-mail
HOSTNAMES=mail.seudominio.com

# Hostname para o Traefik rotear o trafego web (admin + webmail)
# Tambem usado como URL do site (https://MAIL_HOSTNAME)
MAIL_HOSTNAME=mail.seudominio.com

###################################
# RELAY SMTP (envio de e-mail)
###################################

# Servidor de relay para envio (smarthost).
# SMTP2GO:  [mail.smtp2go.com]:2525   (portas: 2525, 587, 8025, 80, 25)
# AWS SES:  [email-smtp.sa-east-1.amazonaws.com]:587
RELAYHOST=[mail.smtp2go.com]:2525

# Credenciais do relay.
# SMTP2GO: criar um SMTP User em Sending -> SMTP Users (NAO e o login da conta)
# AWS SES: SES -> SMTP settings -> Create SMTP credentials
# IMPORTANTE: os nomes sao RELAYUSER / RELAYPASSWORD (sem underscore),
# pois e assim que a imagem do Mailu ativa a autenticacao SASL do relay.
RELAYUSER=
RELAYPASSWORD=

###################################
# TLS
###################################

# Tipo de TLS para portas de e-mail
# letsencrypt = certificado automatico (precisa da porta 80 livre)
# mail        = auto-assinado (recomendado para Easypanel)
# cert        = certificado proprio
# notls       = sem TLS (nao recomendado)
TLS_FLAVOR=mail

###################################
# WEB
###################################

# Path do painel admin
WEB_ADMIN=/admin

# Path do webmail
WEB_WEBMAIL=/webmail

# Cliente webmail (roundcube, snappymail, none)
WEBMAIL=roundcube

# Nome exibido no admin
SITENAME=Mailu

# Habilitar painel admin
ADMIN=true

###################################
# LIMITES
###################################

# Tamanho maximo de e-mail em bytes (50MB)
MESSAGE_SIZE_LIMIT=50000000

# Limite de envio por usuario por dia
MESSAGE_RATELIMIT=200/day

# Rate limit de autenticacao
AUTH_RATELIMIT_IP=60/hour
AUTH_RATELIMIT_USER=100/day

###################################
# REDE
###################################

# Subnet da rede Docker interna (mudar se conflitar com outro projeto)
SUBNET=192.168.203.0/24

# Parte local do postmaster (postmaster@DOMAIN)
POSTMASTER=admin

# Delimitador de sub-endereco (user+tag@domain)
RECIPIENT_DELIMITER=+

# CIDRs com permissao de relay (separados por virgula)
RELAYNETS=

###################################
# BACKUP WORKER
###################################

# Horario do backup diario (formato HH:MM)
BACKUP_SCHEDULE=02:00

# Dias para manter backups locais
BACKUP_RETENTION=30

# Executar backup ao iniciar o container (true/false)
RUN_ON_STARTUP=false

# S3 (deixe S3_BUCKET vazio para backup apenas local)
S3_BUCKET=
S3_PREFIX=mailu-backups
S3_STORAGE_CLASS=STANDARD_IA
S3_RETENTION_DAYS=90
S3_REGION=sa-east-1

# Credenciais AWS para o worker de backup (diferentes das credenciais SES)
# Gerar em IAM -> Users -> mailu-backup -> Security credentials -> Create access key
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

###################################
# AVANCADO
###################################

# Nivel de log (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=WARNING

# Banco de dados (sqlite, mysql, postgresql)
DB_FLAVOR=postgresql

# Configuracoes do PostgreSQL
DB_NAME=mailu
DB_USER=mailu
DB_PW=mailupass

# Antivirus (clamav ou none, clamav usa +2GB RAM)
ANTIVIRUS=none

# Intervalo do fetchmail em segundos
FETCHMAIL_DELAY=600

# Seletor DKIM
DKIM_SELECTOR=dkim

# Desativar envio de estatisticas anonimas
DISABLE_STATISTICS=True
